{
   "name": "PostgreSQL dev container",
   "build": {
        "dockerfile": "Dockerfile",
        "args": { "PGVERSION": "18.3" }
    },
    "mounts": [
      "source=/sys/kernel/debug,target=/sys/kernel/debug,type=bind",
      "source=/sys/fs/bpf,target=/sys/fs/bpf,type=bind"
    ],
    "runArgs": [ "--privileged", "--security-opt", "seccomp=unconfined"],
    "customizations": {
        "vscode": {
          "extensions": [
            "ms-vscode.cpptools",
            "ms-vscode.cmake-tools",
            "ms-azuretools.vscode-docker",
            "streetsidesoftware.code-spell-checker",
            "ms-vscode.cpptools-extension-pack",
            "ms-vscode.makefile-tools",
            "yzhang.markdown-all-in-one",
            "ash-blade.postgresql-hacker-helper"
         ]
        }
     },
    "remoteUser": "vscode",
    "postStartCommand": "pg_ctl start -D /home/vscode/pgdata -l /home/vscode/postgresql.log",
    "forwardPorts": [5432]
}
